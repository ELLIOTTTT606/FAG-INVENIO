{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://france-air.local/invenio/options.schema.json",
  "title": "INVENIO options/accessoires CSV row",
  "description": "Schema d'une ligne du CSV maitre options_accessoires.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "model",
    "family",
    "type",
    "size",
    "option_code",
    "option_category",
    "label_fr",
    "description_fr",
    "available",
    "source_file",
    "last_updated"
  ],
  "properties": {
    "model": {
      "type": "string",
      "minLength": 2,
      "maxLength": 32,
      "pattern": "^[A-Z0-9-]+$"
    },
    "family": {
      "type": "string",
      "enum": ["C", "H", "PAC", "GEG"]
    },
    "type": {
      "type": "string",
      "enum": ["HS", "HL", "CS", "CL"]
    },
    "size": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8,
      "pattern": "^[0-9A-Z]+$"
    },
    "option_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4,
      "pattern": "^[A-Z0-9]+$"
    },
    "option_category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "label_fr": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description_fr": {
      "type": "string",
      "maxLength": 1000
    },
    "tips_fr": {
      "type": "string",
      "maxLength": 1000
    },
    "price_eur": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "available": {
      "type": "boolean"
    },
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "last_updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  }
}
