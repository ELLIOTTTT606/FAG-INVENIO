# INVENIO - example environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Application ---
APP_ENV=development
APP_LOG_LEVEL=INFO

# --- Baserow ---
# Source of truth for clients, options/accessoires, contacts.
BASEROW_URL=https://api.baserow.io
BASEROW_TOKEN=replace-me
# Table IDs documented in docs/architecture.md
BASEROW_TABLE_CLIENTS=939119
BASEROW_TABLE_CONTACTS_FORCE_VENTE=939355
BASEROW_TABLE_CONTACTS_SOLUTION=939361
BASEROW_TABLE_OPTIONS_ACCESSOIRES=941070

# --- Object storage (uploads, generated PDFs, plans) ---
S3_ENDPOINT=
S3_REGION=eu-west-3
S3_BUCKET=invenio-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- PDF generator ---
# Path used by Playwright to find browsers (CI sets this automatically).
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
